# Portas publicadas no host pelos brokers do laboratório.
#
# Os padrões abaixo NÃO são as portas canônicas de RabbitMQ (5672/15672) nem de
# MQTT-over-WebSocket (9001). Elas foram deslocadas de propósito, para que o laboratório
# possa subir ao lado de outros containers que você já tenha rodando — é comum ter um
# RabbitMQ de outro projeto ocupando a 5672.
#
# Dentro da rede do compose, os serviços continuam nas portas padrão. O deslocamento
# existe só na publicação para o host. Se as portas canônicas estiverem livres na sua
# máquina, sinta-se à vontade para trocar aqui e em backend/Gateway/appsettings.json.

MQTT_PORT=1883
MQTT_WS_PORT=9883

AMQP_PORT=5673
AMQP_MANAGEMENT_PORT=15673
